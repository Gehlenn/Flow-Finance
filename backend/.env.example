# ─── API CONFIGURATION ──────────────────────────────────────────────────────

# Backend port (default: 3001)
PORT=3001

# Node environment (development | production | test)
NODE_ENV=development

# Frontend URL for CORS configuration
FRONTEND_URL=http://localhost:5173

# ─── AI & LLM CONFIGURATION ──────────────────────────────────────────────────

# Gemini API key (get it from https://aistudio.google.com/app/apikeys)
GEMINI_API_KEY=your_gemini_api_key_here

# Model to use (default: gemini-2.0-flash or gemini-1.5-pro)
GEMINI_MODEL=gemini-2.0-flash

# ─── AUTHENTICATION ─────────────────────────────────────────────────────────

# JWT secret for signing tokens (use a strong random string in production)
JWT_SECRET=your_jwt_secret_key_here_change_in_production

# JWT token expiration time (default: 7 days = 604800 seconds)
JWT_EXPIRATION=604800

# ─── RATE LIMITING ───────────────────────────────────────────────────────────

# Common limit: max requests per window
RATE_LIMIT_GENERAL_MAX=100
# Window in minutes
RATE_LIMIT_GENERAL_WINDOW=15

# AI endpoint limit: max requests per minute
RATE_LIMIT_AI_MAX=10
RATE_LIMIT_AI_WINDOW=1

# Auth endpoint limit: max requests per window
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_AUTH_WINDOW=15

# ─── LOGGING ─────────────────────────────────────────────────────────────────

# Log level (trace | debug | info | warn | error | fatal)
LOG_LEVEL=info

# Pretty-print logs in development (default: true in dev, false in prod)
LOG_PRETTY=true

# ─── DATABASE (Future Implementation) ─────────────────────────────────────────

# DATABASE_URL=postgresql://user:password@localhost:5432/flow_finance

# ─── MONITORING & OBSERVABILITY ──────────────────────────────────────────────

# Sentry DSN for error tracking (optional)
# SENTRY_DSN=https://your-project-dsn@sentry.io/project-id

# Enable Sentry in development (default: false)
# SENTRY_DEV_ENABLED=false

# New Relic license key (optional)
# NEW_RELIC_LICENSE_KEY=...
