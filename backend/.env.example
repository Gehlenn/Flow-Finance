# ─── API CONFIGURATION ──────────────────────────────────────────────────────

# Backend port (default: 3001)
PORT=3001

# Node environment (development | production | test)
NODE_ENV=development

# Frontend URL for CORS configuration
FRONTEND_URL=http://localhost:5173

# ─── AI & LLM CONFIGURATION ──────────────────────────────────────────────────

# Gemini API key (get it from https://aistudio.google.com/app/apikeys)
GEMINI_API_KEY=your_gemini_api_key_here

# Model to use (default: gemini-2.0-flash or gemini-1.5-pro)
GEMINI_MODEL=gemini-2.0-flash

# ─── AUTHENTICATION ─────────────────────────────────────────────────────────

# JWT secret for signing tokens (use a strong random string in production)
JWT_SECRET=your_jwt_secret_key_here_change_in_production

# Access/refresh token expiration (JWT)
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# OAuth (Google) scaffold
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3001/api/auth/oauth/google/callback
OAUTH_STATE_TTL_SECONDS=600
OAUTH_MOCK_MODE=true

# Billing (SaaS)
ALLOW_MOCK_BILLING_UPDATES=false
SAAS_PRO_MONTHLY_PRICE_CENTS=2990

# Stripe (required for checkout/portal/webhook)
STRIPE_SECRET_KEY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_WEBHOOK_SECRET=

# ─── RATE LIMITING ───────────────────────────────────────────────────────────

# Common limit: max requests per window
RATE_LIMIT_GENERAL_MAX=100
# Window in minutes
RATE_LIMIT_GENERAL_WINDOW=15

# AI endpoint limit: max requests per minute
RATE_LIMIT_AI_MAX=10
RATE_LIMIT_AI_WINDOW=1

# Auth endpoint limit: max requests per window
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_AUTH_WINDOW=15

# ─── LOGGING ─────────────────────────────────────────────────────────────────

# Log level (trace | debug | info | warn | error | fatal)
LOG_LEVEL=info

# Pretty-print logs in development (default: true in dev, false in prod)
LOG_PRETTY=true

# ─── DATABASE (Future Implementation) ─────────────────────────────────────────

# DATABASE_URL=postgresql://user:password@localhost:5432/flow_finance

# Firebase-first strategy for Open Finance persistence.
# Supported values: memory | postgres | firebase
OPEN_FINANCE_STORE_DRIVER=firebase
OPEN_FINANCE_POSTGRES_ENABLED=false
DATABASE_URL=

# Firebase Admin credentials (required when OPEN_FINANCE_STORE_DRIVER=firebase)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_DATABASE_URL=

# ─── MONITORING & OBSERVABILITY ──────────────────────────────────────────────

# Sentry DSN for error tracking (optional)
# SENTRY_DSN=https://your-project-dsn@sentry.io/project-id

# Enable Sentry in development (default: false)
# SENTRY_DEV_ENABLED=false

# New Relic license key (optional)
# NEW_RELIC_LICENSE_KEY=...

# ─── OPEN FINANCE / PLUGGY ────────────────────────────────────────────────────

# Set to 'pluggy' for real connections. Use 'mock' only for local persistence tests.
OPEN_FINANCE_PROVIDER=pluggy

# ⚠️  NEVER expose these in client-side code or version control.
# Get sandbox credentials at https://dashboard.pluggy.ai
# Replace the values below with your actual CLIENT_ID and CLIENT_SECRET.
PLUGGY_CLIENT_ID=your_pluggy_client_id_here
PLUGGY_CLIENT_SECRET=your_pluggy_client_secret_here

# Pluggy API base URL (default is production; use sandbox URL for testing)
PLUGGY_BASE_URL=https://api.pluggy.ai

# Optional: map your app's bankId slugs to Pluggy connector IDs (JSON).
# Find connector IDs at https://dashboard.pluggy.ai/connectors
# Example: {"nubank":201,"itau":176,"bradesco":212}
PLUGGY_BANK_CONNECTORS=

# Optional: default credentials for sandbox automated testing only.
# ⚠️  Never set real user credentials here.
# PLUGGY_DEFAULT_CREDENTIALS_JSON={"cpf":"012.345.678-90","password":"test1234"}

# Optional: protect the public webhook URL using a shared secret.
# Configure the Pluggy webhook URL as:
# https://your-domain/api/banking/webhooks/pluggy?secret=your_shared_secret
PLUGGY_WEBHOOK_SECRET=

