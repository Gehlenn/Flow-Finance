{
    "name": "flow-finance-api",
    "version": "0.6.3",
    "description": "Flow Finance Backend API - Gemini Proxy & Auth Server",
    "main": "dist/index.js",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "lint": "tsc --noEmit",
        "type-check": "tsc --noEmit",
        "preflight:cutover": "tsx scripts/postgres-cutover-preflight.ts",
        "backfill:normalized-state": "tsx scripts/backfill-normalized-state.ts",
        "prebuild": "npm run lint",
        "migrate:normalized-state": "tsx scripts/apply-normalized-migrations.ts",
        "cutover:postgres": "tsx scripts/postgres-cutover-run.ts"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.490.0",
        "@aws-sdk/s3-request-presigner": "^3.490.0",
        "@capacitor/android": "^8.2.0",
        "@capacitor/core": "^8.2.0",
        "@capacitor/ios": "^8.2.0",
        "@google/generative-ai": "^0.12.0",
        "@sentry/node": "^10.42.0",
        "@sentry/profiling-node": "^10.42.0",
        "@sentry/react": "^10.42.0",
        "@sentry/tracing": "^7.120.4",
        "bcrypt": "^5.1.1",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.18.2",
        "express-rate-limit": "^7.1.5",
        "firebase-admin": "^13.7.0",
        "helmet": "^7.1.0",
        "jsonwebtoken": "^9.0.3",
        "multer": "^1.4.5-lts.1",
        "openai": "^4.11.0",
        "pg": "^8.11.3",
        "pino": "^8.17.2",
        "pino-pretty": "^10.3.1",
        "redis": "^4.6.12",
        "zod": "^3.24.1"
    },
    "devDependencies": {
        "@types/bcrypt": "^5.0.2",
        "@types/cors": "^2.8.17",
        "@types/dotenv": "^8.2.0",
        "@types/express": "^4.17.21",
        "@types/helmet": "^4.0.0",
        "@types/jsonwebtoken": "^9.0.7",
        "@types/multer": "^1.4.11",
        "@types/node": "^20.10.6",
        "@types/pg": "^8.11.0",
        "@types/uuid": "^9.0.7",
        "supertest": "^6.3.3",
        "tsx": "^4.7.0",
        "typescript": "^6.0.2"
    },
    "engines": {
        "node": ">=18.0.0"
    }
}
