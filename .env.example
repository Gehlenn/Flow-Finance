# Flow Finance — Environment Configuration
# 
# SECURITY WARNING: Never commit .env file with real values!
# Use .env for local development only. Production uses secure backend environment variables.

# ─── API Configuration ────────────────────────────────────────────────────────

# Backend API URLs (never expose API keys in client code)
# Keep empty for production, backend serves from same domain
VITE_API_DEV_URL=http://localhost:3001
VITE_API_PROD_URL=

# ─── Build & Environment ─────────────────────────────────────────────────────

# App environment
VITE_APP_ENVIRONMENT=development

# Logging level (debug, info, warn, error)
VITE_LOG_LEVEL=debug

# ─── Firebase (Optional Mock) ─────────────────────────────────────────────────

# If using real Firebase, add credentials here (NOT in production!)
# VITE_FIREBASE_API_KEY=your_key
# VITE_FIREBASE_PROJECT_ID=your_project

# ─── Feature Flags ────────────────────────────────────────────────────────────

# Enable/disable features
VITE_FEATURE_AUTOPILOT=true

# ─── Error Tracking & Monitoring ──────────────────────────────────────────────

# Sentry DSN for error tracking (optional)
# Get from https://sentry.io/settings/projects/your-project/keys/
# VITE_SENTRY_DSN=https://your-project-dsn@sentry.io/project-id

# Enable Sentry error reporting in development (default: false)
# VITE_SENTRY_DEV_ENABLED=false

# App version for Sentry releases
VITE_APP_VERSION=0.1.0
VITE_FEATURE_OPEN_BANKING=true
VITE_FEATURE_RECEIPT_SCANNER=true
VITE_FEATURE_AI_CFO=true

# ─── NEVER set these in .env (backend only) ──────────────────────────────────

# These MUST NEVER be in client code:
# - GEMINI_API_KEY (backend proxy only)
# - Firebase private keys
# - OAuth client secrets
# - Database credentials

# For development, use mock services instead of real APIs.
# See services/localService.ts for mock implementations.
