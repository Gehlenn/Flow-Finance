# Flow Finance — Environment Configuration
#
# SECURITY WARNING: Never commit .env file with real values!
# Use .env for local development only. Production uses secure backend environment variables.

# ─── API Configuration ────────────────────────────────────────────────────────

# Backend API URLs (never expose API keys in client code)
# Keep empty for production, backend serves from same domain
VITE_API_DEV_URL=http://localhost:3001
VITE_API_PROD_URL=

# ─── Build & Environment ─────────────────────────────────────────────────────

# App environment
VITE_APP_ENVIRONMENT=development

# Logging level (debug, info, warn, error)
VITE_LOG_LEVEL=debug

# ─── Backend Environment Variables ───────────────────────────────────────────

# Database Configuration
DATABASE_URL=postgresql://flowfinance:flowfinance_password@localhost:5432/flowfinance

# Redis Configuration
REDIS_URL=redis://localhost:6379

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-minimum-32-characters
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# AI Services (backend proxy only)
# You can supply either an OpenAI key (GPT‑4) or a Gemini key.
# For personal use the GPT‑Go key keeps you within your subscription.
OPENAI_API_KEY=your-openai-api-key-here
#GEMINI_API_KEY=your-gemini-api-key-here  # optional if you prefer Gemini vision/ocr

# Sentry Configuration (Error Tracking & Performance)
SENTRY_DSN=https://your-sentry-dsn-here@sentry.io/project-id
SENTRY_ENVIRONMENT=development

# Cloud Storage (AWS S3, Cloudflare R2, etc.)
CLOUD_STORAGE_PROVIDER=aws-s3
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_S3_BUCKET=flow-finance-storage
AWS_REGION=us-east-1

# Alternative: Cloudflare R2
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_ACCESS_KEY_ID=your-cloudflare-access-key-id
CLOUDFLARE_SECRET_ACCESS_KEY=your-cloudflare-secret-access-key
CLOUDFLARE_R2_BUCKET=flow-finance-storage

# Email Service (for notifications, password reset, etc.)
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=your-sendgrid-api-key
FROM_EMAIL=noreply@flowfinance.com

# Alternative: AWS SES
AWS_SES_REGION=us-east-1

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,https://flowfinance.com

# Security
BCRYPT_ROUNDS=12
SESSION_SECRET=your-session-secret-change-this-in-production

# Monitoring & Analytics
ANALYTICS_ENABLED=false
ANALYTICS_TRACKING_ID=your-google-analytics-id

# Feature Flags
ENABLE_AI_FEATURES=true
ENABLE_SUBSCRIPTIONS=false
ENABLE_BANK_SYNC=false

# ─── Development Only ────────────────────────────────────────────────────────

# Debug mode (disable in production)
DEBUG=true

# Hot reload (disable in production)
HOT_RELOAD=true

# Mock services (disable in production)
USE_MOCK_SERVICES=false

# ─── Firebase (Optional Mock) ─────────────────────────────────────────────────

# If using real Firebase, add credentials here (NOT in production!)
# VITE_FIREBASE_API_KEY=your_key
# VITE_FIREBASE_PROJECT_ID=your_project

# ─── Feature Flags ────────────────────────────────────────────────────────────

# Enable/disable features
VITE_FEATURE_AUTOPILOT=true
VITE_AI_DEBUG_PANEL=false

# ─── Error Tracking & Monitoring ──────────────────────────────────────────────

# Sentry DSN for error tracking (optional)
# Get from https://sentry.io/settings/projects/your-project/keys/
# VITE_SENTRY_DSN=https://your-project-dsn@sentry.io/project-id

# Enable Sentry error reporting in development (default: false)
# VITE_SENTRY_DEV_ENABLED=false

# App version for Sentry releases
VITE_APP_VERSION=0.1.0
VITE_FEATURE_OPEN_BANKING=true
VITE_FEATURE_RECEIPT_SCANNER=true
VITE_FEATURE_AI_CFO=true

# ─── NEVER set these in .env (backend only) ──────────────────────────────────

# These MUST NEVER be in client code:
# - GEMINI_API_KEY (backend proxy only)
# - Firebase private keys
# - OAuth client secrets
# - Database credentials

# For development, use mock services instead of real APIs.
# See services/localService.ts for mock implementations.
