# Flow Finance — Environment Configuration (Local Development)
#
# SECURITY WARNING: Never commit this file with real values!
# Add to .gitignore and only use locally
# Production: Use Vercel Environment Variables dashboard instead

# ─── FRONTEND CONFIGURATION ──────────────────────────────────────────────────

# Backend API URLs
VITE_API_DEV_URL=http://localhost:3001
VITE_API_PROD_URL=https://your-backend.vercel.app

# App Configuration
VITE_APP_VERSION=0.3.1
VITE_APP_ENVIRONMENT=development
VITE_LOG_LEVEL=debug
VITE_AI_DEBUG_PANEL=true

# Sentry Error Tracking
VITE_SENTRY_DSN=
VITE_SENTRY_DEV_ENABLED=false

# Firebase Configuration (Optional - if using Firebase directly)
VITE_FIREBASE_API_KEY=your_firebase_web_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:yourfirebaseappid
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── BACKEND CONFIGURATION ──────────────────────────────────────────────────

# Port Configuration
PORT=3001
NODE_ENV=development

# Database Configuration
DATABASE_URL=postgresql://flowfinance:password@localhost:5432/flowfinance_dev
REDIS_URL=redis://localhost:6379

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-minimum-32-characters
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ─── AI SERVICES (OpenAI / GPT-4) ───────────────────────────────────────────

# OpenAI Configuration (REQUIRED for GPT-4)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_MAX_TOKENS=4096

# Optional: Gemini for Receipt Scanning (OCR)
# Only set if you want to use Gemini for specific tasks
# GEMINI_API_KEY=your-gemini-api-key-here

# ─── FIREBASE ADMIN SDK ──────────────────────────────────────────────────────

# Firebase Admin SDK (for backend operations)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_CONTENT\n-----END PRIVATE KEY-----\n
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com

# ─── ERROR TRACKING & MONITORING ───────────────────────────────────────────

# Sentry Configuration
SENTRY_DSN=https://your-key@sentry.io/your-project-id
SENTRY_ENVIRONMENT=development

# ─── OPTIONAL: Cloud Storage ───────────────────────────────────────────────

# Cloud Storage Configuration (for receipts/documents)
CLOUD_STORAGE_PROVIDER=firebase
# AWS_ACCESS_KEY_ID=your-aws-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret
# AWS_S3_BUCKET=flow-finance-storage
# AWS_REGION=us-east-1
