<!--
  Referencia Info.plist (Capacitor / iOS)

  Este arquivo e uma referencia de chaves que podem ser exigidas pelo iOS
  dependendo das features ativas.

  Onde aplicar (projeto nativo):
  - ios/App/App/Info.plist

  Regra pratica:
  - nunca pedir permissao que o app nao usa
  - manter textos claros e verdadeiros (App Store)
-->

<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Opcional: camera (scanner/import por imagem) -->
  <key>NSCameraUsageDescription</key>
  <string>O Flow Finance precisa acessar sua camera para importar imagens de comprovantes.</string>

  <!-- Opcional: fotos (import/export) -->
  <key>NSPhotoLibraryUsageDescription</key>
  <string>O Flow Finance pode acessar suas fotos para importar documentos financeiros.</string>
  <key>NSPhotoLibraryAddOnlyUsageDescription</key>
  <string>O Flow Finance pode salvar arquivos exportados na sua biblioteca de fotos.</string>

  <!-- Opcional: microfone (entrada por voz) -->
  <key>NSMicrophoneUsageDescription</key>
  <string>O Flow Finance pode usar o microfone para comandos de voz financeiros.</string>

  <!-- Opcional: files app / import/export via app Arquivos -->
  <key>UIFileSharingEnabled</key>
  <true/>
  <key>LSSupportsOpeningDocumentsInPlace</key>
  <true/>

  <!-- ATS: permitir http apenas para localhost (desenvolvimento) -->
  <key>NSAppTransportSecurity</key>
  <dict>
    <key>NSAllowsArbitraryLoads</key>
    <false/>
    <key>NSExceptionDomains</key>
    <dict>
      <key>localhost</key>
      <dict>
        <key>NSIncludesSubdomains</key>
        <true/>
        <key>NSTemporaryExceptionAllowsInsecureHTTPLoads</key>
        <true/>
        <key>NSTemporaryExceptionMinimumTLSVersion</key>
        <string>TLSv1.2</string>
      </dict>
    </dict>
  </dict>
</dict>
</plist>
