<!--
  Referencia AndroidManifest.xml (Capacitor)

  Este arquivo e uma referencia de permissoes/configuracoes que podem ser
  necessarias no app Android, dependendo das features ativas.

  Onde aplicar (projeto nativo):
  - android/app/src/main/AndroidManifest.xml

  Regra pratica:
  - nao habilitar permissoes que o app nao usa
  - tratar storage/permissoes legadas com cautela (Android moderno usa scoped storage)
-->

<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.flowfinance.app">

    <!-- Basico (comunicacao) -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Notificacoes (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Opcional: camera (scanner/import por imagem) -->
