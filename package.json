{
  "name": "flow-finance",
  "description": "Flow Finance - Intelligent Cash Flow Control App (v0.5.0 Advanced Analytics & Performance)",
  "private": true,
  "version": "0.5.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "type-check": "tsc --noEmit",
    "docs:update": "node scripts/update-readme.js",
    "resources:generate": "cordova-res android && cordova-res ios",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "setup:mobile": "cap add android && cap add ios && cap sync",
    "build:android": "npm run build && cap sync android && cap build android",
    "build:android:release": "npm run build && cap sync android && cap build android --prod",
    "build:ios": "npm run build && cap sync ios && cap build ios",
    "build:ios:release": "npm run build && cap sync ios && cap build ios --prod",
    "cap:build:android": "npx cap build android",
    "cap:build:ios": "npx cap build ios",
    "cap:sync": "npx cap sync"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@google/genai": "1.40.0",
    "@google/generative-ai": "^0.24.1",
    "@sentry/react": "^10.42.0",
    "@sentry/tracing": "^7.120.4",
    "firebase": "^12.9.0",
    "lucide-react": "0.563.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "3.7.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.2.0",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "cordova-res": "^0.15.4",
    "jsdom": "^28.1.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.0.18"
  }
}
