{
  "name": "flow-finance",
  "description": "Flow Finance - Intelligent Cash Flow Control App (release v0.9.6)",
  "private": true,
  "version": "0.9.6",
  "type": "module",
  "scripts": {
    "setup": "node setup.js",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "vault:sync": "node scripts/sync-obsidian-vault.mjs",
    "vault:summaries": "node scripts/generate-obsidian-summaries.mjs",
    "vault:refresh": "npm run vault:sync && npm run vault:summaries",
    "lint": "npm run type-check:app && npm run type-check:backend",
    "type-check": "npm run type-check:app && npm run type-check:backend",
    "type-check:app": "tsc -p tsconfig.app.json --noEmit",
    "type-check:backend": "npm --prefix backend run type-check",
    "docs:update": "node scripts/update-readme.js",
    "deploy": "vercel --prod",
    "deploy:preview": "vercel",
    "teste": "npm test",
    "test": "node scripts/run-vitest-stable.mjs",
    "test:backend": "vitest run backend/tests/unit",
    "test:unit": "node scripts/run-vitest-stable.mjs",
    "test:firestore:rules": "node scripts/run-firestore-rules.mjs",
    "test:watch": "vitest --exclude tests/e2e/**",
    "test:coverage": "vitest run --coverage --exclude tests/e2e/** --exclude tests/firestore/** --passWithNoTests",
    "test:ci": "node scripts/run-vitest-stable.mjs",
    "test:coverage:critical": "vitest run --config vitest.critical.config.ts",
    "validate:cfo:route": "node scripts/validate-cfo-route.mjs",
    "health:vercel": "node scripts/verify-vercel-observability.mjs https://flow-finance-backend.vercel.app",
    "health:io": "vitest run --pool=threads tests/health/io-integrations.health.test.ts",
    "health:runtime": "playwright test tests/e2e/runtime-console-health.spec.ts --project=chromium --workers=1",
    "health:runtime:mobile": "playwright test tests/e2e/runtime-console-health.spec.ts --project=\"Mobile Chrome\" --project=\"Mobile Safari\" --workers=1",
    "health:all": "npm run health:io ; npm run health:runtime ; npm run health:runtime:mobile",
    "teste:e2e": "npm run test:e2e",
    "test:e2e": "playwright test",
    "db:reset": "node scripts/reset-database.mjs",
    "security:scan-secrets": "node scripts/scan-secrets.mjs",
    "setup:mobile": "cap add android && cap add ios && cap sync",
    "build:android": "npm run build && cap sync android && cap build android",
    "build:android:release": "npm run build && cap sync android && cap build android --prod",
    "build:ios": "npm run build && cap sync ios && cap build ios",
    "build:ios:release": "npm run build && cap sync ios && cap build ios --prod",
    "cap:build:android": "npx cap build android",
    "cap:build:ios": "npx cap build ios",
    "cap:sync": "npx cap sync",
    "health:auth-local": "node scripts/check-local-auth-readiness.mjs"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@google/genai": "^1.40.0",
    "@google/generative-ai": "^0.24.1",
    "@sentry/react": "^10.47.0",
    "@sentry/tracing": "^7.120.4",
    "@vercel/analytics": "^2.0.1",
    "decimal.js": "^10.4.3",
    "esbuild": "^0.28.0",
    "fdir": "^6.5.0",
    "firebase": "^12.9.0",
    "lucide-react": "0.563.0",
    "pdf-parse": "^2.4.5",
    "picomatch": "^4.0.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-pluggy-connect": "^2.12.0",
    "recharts": "3.7.0",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.2.0",
    "@firebase/rules-unit-testing": "^5.0.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.27",
    "express": "^5.2.1",
    "firebase-tools": "^15.12.0",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.8",
    "rollup": "^4.60.1",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.0.18"
  }
}
